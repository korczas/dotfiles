# Per-machine / per-env zsh config (work, private, ...)
#
# This file is a TEMPLATE. `scripts/setup_symlinks.sh` copies it to
# `zsh/.zshrc.local` (gitignored) and symlinks that to `~/.zshrc.local`, which the
# core `.zshrc` sources LAST — so anything here overrides the shared config.
#
# Put machine-specific aliases, exports, and functions here. Nothing in this file
# is committed, so it is safe for work-only tooling and secrets.

# --- Examples -------------------------------------------------------------------

# export SOME_WORK_TOKEN="..."
# alias vpn="..."

